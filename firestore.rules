rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function getCurrentUserRole(companyId) {
      return getUserDoc(request.auth.uid).role;
    }

    function isUserInCompany(companyId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserDoc(request.auth.uid).companyId == companyId;
    }

    function hasRolePermission(companyId, permission) {
      let role = getCurrentUserRole(companyId);
      return (
        (role == 'owner') ||
        (role == 'admin' && permission in ['submissions:read', 'submissions:write', 'team:manage', 'webhooks:write', 'integrations:write', 'analytics:read', 'audit:read']) ||
        (role == 'manager' && permission in ['submissions:read', 'submissions:write', 'submissions:reply', 'analytics:read', 'audit:read']) ||
        (role == 'viewer' && permission in ['submissions:read', 'analytics:read'])
      );
    }

    function canManageCompany(companyId) {
      return isUserInCompany(companyId) &&
        (getCurrentUserRole(companyId) == 'owner' || getCurrentUserRole(companyId) == 'admin');
    }

    function isOwner(companyId) {
      return isUserInCompany(companyId) && getCurrentUserRole(companyId) == 'owner';
    }

    function canManageTeam(companyId) {
      return isUserInCompany(companyId) &&
        (getCurrentUserRole(companyId) == 'owner' || getCurrentUserRole(companyId) == 'admin');
    }

    function canReadSubmissions(companyId) {
      return isUserInCompany(companyId) &&
        getCurrentUserRole(companyId) in ['owner', 'admin', 'manager', 'viewer'];
    }

    function canManageSubmissions(companyId) {
      return isUserInCompany(companyId) &&
        (getCurrentUserRole(companyId) in ['owner', 'admin', 'manager']);
    }

    function canReplyToSubmissions(companyId) {
      return isUserInCompany(companyId) &&
        (getCurrentUserRole(companyId) in ['owner', 'admin', 'manager']);
    }

    // Returns true when the update touches only the listed fields
    function only(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // Validate tracking code format: #FSV-<exactly 4 uppercase alphanumeric chars>
    function isValidTrackingCode(code) {
      return code is string && code.matches('#FSV-[A-Z0-9]{4}');
    }

    // Validate submission fields on direct create (Cloud Functions bypass rules)
    function isValidSubmissionCreate() {
      let d = request.resource.data;
      return d.boardId is string && d.boardId.size() > 0 && d.boardId.size() <= 128 &&
             d.companyId is string && d.companyId.size() > 0 && d.companyId.size() <= 128 &&
             d.subject is string && d.subject.size() > 0 && d.subject.size() <= 100 &&
             d.description is string && d.description.size() > 0 && d.description.size() <= 5000 &&
             d.trackingCode is string && isValidTrackingCode(d.trackingCode) &&
             d.status == 'received' &&
             d.priority in ['low', 'medium', 'high', 'critical'] &&
             d.isAnonymous is bool;
    }

    // Webhook logs - Cloud Functions write, Admin+ read
    match /webhook_logs/{companyId}/{logId} {
      allow read: if canManageCompany(companyId);
      allow write: if false;
    }

    // Users collection - RBAC enforced
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isUserInCompany(resource.data.companyId);
      // Create: only the authenticated user may create their own doc; role must be valid
      allow create: if request.auth.uid == userId &&
        request.resource.data.id == userId &&
        request.resource.data.companyId is string &&
        request.resource.data.role in ['owner', 'admin', 'manager', 'viewer'];
      // Update: self-update OR manager/admin update that keeps companyId unchanged
      allow update: if (request.auth.uid == userId && request.resource.data.companyId == resource.data.companyId) ||
        (canManageTeam(resource.data.companyId) && request.resource.data.companyId == resource.data.companyId);
      // Delete: team managers may remove other users; cannot self-delete
      allow delete: if canManageTeam(resource.data.companyId) && request.auth.uid != userId;
    }

    // Companies collection
    match /companies/{companyId} {
      // Public get: branding data needed on the public submit-feedback and tracking pages
      allow get: if true;
      allow list: if canManageCompany(companyId);
      // Self-service create: the signing-up user may create the company whose ID equals
      // their own UID (this is the pattern used in signUp / loginWithGoogle / loginWithApple).
      // No user doc exists yet at this point so canManageCompany would fail.
      allow create: if request.auth != null && request.auth.uid == companyId;
      allow update: if canManageCompany(companyId);
      allow delete: if isOwner(companyId);

      match /webhook_logs/{logId} {
        allow read: if canManageCompany(companyId);
        allow write: if false;
      }

      match /audit_logs/{logId} {
        allow read: if canManageCompany(companyId);
        // Authenticated company members may create audit log entries; no updates/deletes
        allow create: if isUserInCompany(companyId);
        allow update, delete: if false;
      }

      // Notifications for @mentions
      match /notifications/{notificationId} {
        allow read: if isUserInCompany(companyId) && resource.data.userId == request.auth.uid;
        allow create: if isUserInCompany(companyId);
        allow update: if isUserInCompany(companyId) && resource.data.userId == request.auth.uid;
      }

      // Saved filters - company members can manage their shared filters
      match /filters/{filterId} {
        allow read: if isUserInCompany(companyId);
        allow create: if isUserInCompany(companyId);
        allow update: if isUserInCompany(companyId);
        allow delete: if isUserInCompany(companyId);
      }
    }

    // Board templates - all authenticated users may read; authenticated users may seed
    match /board_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Boards collection - Role-based access; board doc must carry companyId
    match /boards/{boardId} {
      // Public read: board config is needed by the public submit-feedback form
      // (slug query) and the public tracking page (get by ID)
      allow read: if true;
      // create: resource doesn't exist yet, so use request.resource.data
      allow create: if canManageCompany(request.resource.data.companyId);
      // Allow anyone to increment submissionCount by exactly 1 (public form submissions)
      allow update: if canManageCompany(resource.data.companyId) ||
        (only(['submissionCount']) &&
         request.resource.data.submissionCount == resource.data.submissionCount + 1);
      allow delete: if isOwner(resource.data.companyId);
    }

    // Submissions collection - Role-based access
    match /submissions/{submissionId} {
      // Authenticated company members can read their own submissions
      allow read: if canReadSubmissions(resource.data.companyId);
      // Public tracking page: unauthenticated get by document ID
      allow get: if resource.data.trackingCode is string;
      // Public tracking page: query by tracking code (open to all, limit enforced)
      allow list: if request.query.limit <= 1;
      // Authenticated company member create
      allow create: if isUserInCompany(request.resource.data.companyId) && isValidSubmissionCreate();
      // Public (unauthenticated) create from the feedback form
      allow create: if !isAuthenticated() && isValidSubmissionCreate();
      allow update: if canManageSubmissions(resource.data.companyId) ||
        (canReplyToSubmissions(resource.data.companyId) && only(['publicReply', 'publicReplyAt', 'publicReplyBy']));
      allow delete: if canManageCompany(resource.data.companyId);

      // Attachments subcollection - company members read; Cloud Functions write
      match /attachments/{attachmentId} {
        allow read: if canReadSubmissions(
          get(/databases/$(database)/documents/submissions/$(submissionId)).data.companyId
        );
        allow write: if false;
      }

      // Comments subcollection - company members read; authors manage their own comments
      match /comments/{commentId} {
        allow read: if canReadSubmissions(
          get(/databases/$(database)/documents/submissions/$(submissionId)).data.companyId
        );
        allow create: if isAuthenticated() &&
          isUserInCompany(request.resource.data.companyId) &&
          request.resource.data.author.id == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() > 0 &&
          request.resource.data.content.size() <= 5000 &&
          request.resource.data.mentions.size() <= 15 &&
          request.resource.data.mentions.all(uid,
            exists(/databases/$(database)/documents/users/$(uid)) &&
            get(/databases/$(database)/documents/users/$(uid)).data.companyId == request.resource.data.companyId
          );
        allow update: if isAuthenticated() &&
          request.auth.uid == resource.data.author.id &&
          (request.resource.data.content != resource.data.content ||
           request.resource.data.reactions != resource.data.reactions) &&
          request.resource.data.author == resource.data.author;
        allow delete: if isAuthenticated() && request.auth.uid == resource.data.author.id;
      }
    }

    // API Keys collection - Admin+ only
    match /api_keys/{companyId}/{keyId} {
      allow read: if canManageCompany(companyId);
      allow write: if canManageCompany(companyId);
    }

    // API Logs - server-only writes, Admin+ reads
    match /api_logs/{companyId}/{logId} {
      allow read: if canManageCompany(companyId);
      allow write: if false;
    }

    // Team invitations - flat collection used by client code
    match /teamInvitations/{inviteId} {
      allow read: if isAuthenticated() && canManageTeam(resource.data.companyId);
      allow create: if isAuthenticated() && canManageTeam(request.resource.data.companyId);
      allow delete: if isAuthenticated() && canManageTeam(resource.data.companyId);
      allow update: if false;
    }

    // Team invitations - Team managers and above (legacy nested path)
    match /team_invitations/{companyId}/{inviteId} {
      allow read: if canManageTeam(companyId);
      allow create: if canManageTeam(companyId);
      allow delete: if canManageTeam(companyId);
    }

    // Audit logs - Admin+ read only
    match /audit_logs/{companyId}/{logId} {
      allow read: if canManageCompany(companyId);
      allow write: if false;
    }

    // Virus scan queue - Cloud Functions only
    match /virus_scan_queue/{scanId} {
      allow read, write: if false;
    }

    // Per-IP rate limit tracking for public endpoints - Cloud Functions only
    match /_rate_limits/{docId} {
      allow read, write: if false;
    }

    // Bulk operations - Cloud Functions writes, Owner/Admin/Manager reads
    match /bulkOperations/{operationId} {
      allow read: if isAuthenticated() &&
        isUserInCompany(resource.data.companyId) &&
        (getCurrentUserRole(resource.data.companyId) in ['owner', 'admin', 'manager']);
      allow write: if false;
    }

    // Bulk operation logs - Cloud Functions writes, Owner/Admin reads
    match /bulkOperationLogs/{logId} {
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)) &&
        isUserInCompany(resource.data.companyId) &&
        (getCurrentUserRole(resource.data.companyId) in ['owner', 'admin']);
      allow write: if false;
    }

    // Undo operations - Cloud Functions writes, Owner/Admin/Manager reads
    match /undoOperations/{undoId} {
      allow read: if isAuthenticated() &&
        isUserInCompany(resource.data.companyId) &&
        (getCurrentUserRole(resource.data.companyId) in ['owner', 'admin', 'manager']);
      allow write: if false;
    }

    // Archived submissions - Cloud Functions write, Owner/Admin read (compliance)
    match /archived_submissions/{submissionId} {
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/submissions/$(submissionId)) == false &&
        canManageCompany(resource.data.companyId);
      allow write: if false;
    }

    // Deny all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
